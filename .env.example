# AlphaVibes Backend — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   uvicorn app.main:app --reload

# ── Server ────────────────────────────────────────────────────────────────
# Port the server listens on (Railway sets this automatically)
PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development: http://localhost:3000
# Production: your Vercel URL, e.g. https://alphavibes.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Redis Cache (OPTIONAL) ────────────────────────────────────────────────
# Leave empty to run without cache (works perfectly for development).
# For production: use Upstash Redis free tier (10,000 commands/day free).
#
# How to get a free Upstash Redis URL:
#   1. Go to https://upstash.com
#   2. Sign up free (no credit card)
#   3. Create a Redis database → choose "Global" region
#   4. Copy the "Redis URL" (starts with rediss://)
#   5. Paste it here
#
REDIS_URL=

# ── Rate Limiting ─────────────────────────────────────────────────────────
# Set to true during local development to never hit 429 errors.
# ALWAYS set to false (or remove) in production.
DISABLE_RATE_LIMIT=true

# Number of unique stock analyses allowed per session window.
# Each ticker only counts once — re-analysing the same stock is free.
RATE_LIMIT=10

# Window duration in seconds (18000 = 5 hours)
RATE_WINDOW_SECONDS=18000

# ── Deployment ────────────────────────────────────────────────────────────
# Set by Railway automatically — used to add your Railway URL to CORS
RAILWAY_STATIC_URL=

# Set by Vercel for the frontend — used to whitelist the frontend URL
VERCEL_URL=
